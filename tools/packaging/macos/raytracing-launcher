#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
APP_CONTENTS_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
RES_DIR="$APP_CONTENTS_DIR/Resources"
TOOLS_DIR="$RES_DIR/bin"
APP_SUPPORT_DIR_DEFAULT="${HOME}/Library/Application Support/RayTracing"
APP_SUPPORT_DIR="${RAY_TRACING_APP_SUPPORT_DIR:-$APP_SUPPORT_DIR_DEFAULT}"
RUNTIME_DIR_DEFAULT="$APP_SUPPORT_DIR/runtime"
RUNTIME_DIR="${RAY_TRACING_RUNTIME_DIR:-$RUNTIME_DIR_DEFAULT}"
LOG_DIR="${HOME}/Library/Logs/RayTracing"
LOG_FILE="$LOG_DIR/launcher.log"
MOLTENVK_DYLIB="$APP_CONTENTS_DIR/Frameworks/libMoltenVK.dylib"
VK_RUNTIME_DIR=""
VK_ICD_FILE=""

mkdir -p "$LOG_DIR" 2>/dev/null || true
if ! touch "$LOG_FILE" 2>/dev/null; then
    LOG_FILE="${TMPDIR:-/tmp}/raytracing-launcher.log"
    touch "$LOG_FILE" 2>/dev/null || true
fi

setup_runtime_root() {
    mkdir -p "$RUNTIME_DIR" 2>/dev/null || true
    if [ ! -d "$RUNTIME_DIR" ]; then
        RUNTIME_DIR="${TMPDIR:-/tmp}/RayTracing/runtime"
        mkdir -p "$RUNTIME_DIR" 2>/dev/null || true
    fi
    if [ ! -d "$RUNTIME_DIR" ]; then
        echo "failed to create writable runtime directory" >&2
        exit 1
    fi

    mkdir -p "$RUNTIME_DIR/data/runtime/frames" \
        "$RUNTIME_DIR/data/runtime/videos" \
        "$RUNTIME_DIR/data/snapshots" 2>/dev/null || true

    for lane in config shared shaders vk_renderer; do
        target="$RUNTIME_DIR/$lane"
        source="$RES_DIR/$lane"
        if [ -L "$target" ] || [ -e "$target" ]; then
            continue
        fi
        if [ -e "$source" ]; then
            ln -s "$source" "$target"
        fi
    done
}

setup_runtime_root

export VK_RENDERER_SHADER_ROOT="${VK_RENDERER_SHADER_ROOT:-$RUNTIME_DIR}"
export SHAPE_ASSET_DIR="${SHAPE_ASSET_DIR:-$RUNTIME_DIR/config/objects}"
export RAY_TRACING_USE_SHARED_THEME="${RAY_TRACING_USE_SHARED_THEME:-1}"
export RAY_TRACING_USE_SHARED_THEME_FONT="${RAY_TRACING_USE_SHARED_THEME_FONT:-1}"
export RAY_TRACING_USE_SHARED_FONT="${RAY_TRACING_USE_SHARED_FONT:-1}"
export RAY_TRACING_FONT_PRESET="${RAY_TRACING_FONT_PRESET:-ide}"
export RAY_TRACING_RENDER_METRICS_DATASET_PATH="${RAY_TRACING_RENDER_METRICS_DATASET_PATH:-$RUNTIME_DIR/data/runtime/render_metrics.dataset.json}"
if [ -x "$TOOLS_DIR/ffmpeg" ] && [ -z "${RAY_TRACING_FFMPEG_BIN:-}" ]; then
    export RAY_TRACING_FFMPEG_BIN="$TOOLS_DIR/ffmpeg"
fi
export PATH="$TOOLS_DIR:/opt/homebrew/bin:/usr/local/bin:${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"

if [ -f "$MOLTENVK_DYLIB" ]; then
    VK_RUNTIME_DIR="$RUNTIME_DIR/vk"
    VK_ICD_FILE="$VK_RUNTIME_DIR/MoltenVK_icd.json"
    if ! mkdir -p "$VK_RUNTIME_DIR" 2>/dev/null; then
        VK_RUNTIME_DIR="${TMPDIR:-/tmp}/RayTracing/vk"
        VK_ICD_FILE="$VK_RUNTIME_DIR/MoltenVK_icd.json"
        mkdir -p "$VK_RUNTIME_DIR" 2>/dev/null || true
    fi
    if [ -d "$VK_RUNTIME_DIR" ]; then
        cat >"$VK_ICD_FILE" <<EOF
{
  "file_format_version": "1.0.0",
  "ICD": {
    "library_path": "$MOLTENVK_DYLIB",
    "api_version": "1.3.0"
  }
}
EOF
        if [ -z "${VK_ICD_FILENAMES:-}" ]; then
            export VK_ICD_FILENAMES="$VK_ICD_FILE"
        fi
        if [ -z "${VK_DRIVER_FILES:-}" ]; then
            export VK_DRIVER_FILES="$VK_ICD_FILE"
        fi
    fi
fi

if [ "${1:-}" = "--print-config" ]; then
    echo "APP_CONTENTS_DIR=$APP_CONTENTS_DIR"
    echo "RES_DIR=$RES_DIR"
    echo "LOG_FILE=$LOG_FILE"
    echo "RAY_TRACING_RUNTIME_DIR=$RUNTIME_DIR"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "SHAPE_ASSET_DIR=$SHAPE_ASSET_DIR"
    echo "RAY_TRACING_USE_SHARED_THEME=$RAY_TRACING_USE_SHARED_THEME"
    echo "RAY_TRACING_USE_SHARED_THEME_FONT=$RAY_TRACING_USE_SHARED_THEME_FONT"
    echo "RAY_TRACING_USE_SHARED_FONT=$RAY_TRACING_USE_SHARED_FONT"
    echo "RAY_TRACING_FONT_PRESET=$RAY_TRACING_FONT_PRESET"
    echo "RAY_TRACING_RENDER_METRICS_DATASET_PATH=$RAY_TRACING_RENDER_METRICS_DATASET_PATH"
    echo "RAY_TRACING_FFMPEG_BIN=${RAY_TRACING_FFMPEG_BIN:-}"
    echo "PATH=$PATH"
    echo "VK_ICD_FILENAMES=${VK_ICD_FILENAMES:-}"
    echo "VK_DRIVER_FILES=${VK_DRIVER_FILES:-}"
    echo "MOLTENVK_DYLIB=$MOLTENVK_DYLIB"
    exit 0
fi

if [ "${1:-}" = "--self-test" ]; then
    [ -x "$SCRIPT_DIR/raytracing-bin" ] || { echo "missing: raytracing-bin" >&2; exit 1; }
    [ -f "$APP_CONTENTS_DIR/Info.plist" ] || { echo "missing: Info.plist" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/config/animation_config.json" ] || { echo "missing: config/animation_config.json" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/config/scene_config.json" ] || { echo "missing: config/scene_config.json" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/config/default.ttf" ] || { echo "missing: config/default.ttf" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/config/objects/Hexagon.asset.json" ] || { echo "missing: bundled shape assets" >&2; exit 1; }
    [ -d "$RUNTIME_DIR/data/runtime" ] || { echo "missing: runtime dir" >&2; exit 1; }
    [ -d "$RUNTIME_DIR/data/runtime/frames" ] || { echo "missing: runtime frames dir" >&2; exit 1; }
    [ -d "$RUNTIME_DIR/data/runtime/videos" ] || { echo "missing: runtime videos dir" >&2; exit 1; }
    if [ -n "${RAY_TRACING_FFMPEG_BIN:-}" ]; then
        [ -x "$RAY_TRACING_FFMPEG_BIN" ] || { echo "missing: configured ffmpeg binary" >&2; exit 1; }
    fi
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/textured.vert.spv" ] || { echo "missing: bundled vk_renderer shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/textured.vert.spv" ] || { echo "missing: bundled runtime shader" >&2; exit 1; }
    [ -f "$MOLTENVK_DYLIB" ] || { echo "missing: bundled MoltenVK dylib" >&2; exit 1; }
    [ -d "$RUNTIME_DIR" ] || { echo "missing: runtime state dir ($RUNTIME_DIR)" >&2; exit 1; }
    echo "self-test: ok"
    echo "LOG_FILE=$LOG_FILE"
    echo "RAY_TRACING_RUNTIME_DIR=$RUNTIME_DIR"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "SHAPE_ASSET_DIR=$SHAPE_ASSET_DIR"
    echo "RAY_TRACING_FONT_PRESET=$RAY_TRACING_FONT_PRESET"
    echo "RAY_TRACING_RENDER_METRICS_DATASET_PATH=$RAY_TRACING_RENDER_METRICS_DATASET_PATH"
    echo "RAY_TRACING_FFMPEG_BIN=${RAY_TRACING_FFMPEG_BIN:-}"
    echo "PATH=$PATH"
    echo "VK_ICD_FILENAMES=${VK_ICD_FILENAMES:-}"
    echo "VK_DRIVER_FILES=${VK_DRIVER_FILES:-}"
    echo "MOLTENVK_DYLIB=$MOLTENVK_DYLIB"
    exit 0
fi

cd "$RUNTIME_DIR"
printf '%s launch begin pid=%s cwd=%s runtime_dir=%s shader_root=%s shape_asset_dir=%s args=%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S')" "$$" "$RUNTIME_DIR" "$RUNTIME_DIR" "$VK_RENDERER_SHADER_ROOT" "$SHAPE_ASSET_DIR" "$*" >>"$LOG_FILE" 2>/dev/null || true
exec "$SCRIPT_DIR/raytracing-bin" "$@" >>"$LOG_FILE" 2>&1
